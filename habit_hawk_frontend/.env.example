# Habit Hawk Frontend Environment Configuration

# API Base URL
# For development with backend running on localhost:8000
# Expo will automatically use the correct localhost for the platform:
# - Web: http://localhost:8000
# - iOS Simulator: http://[YOUR_IP]:8000
# - Android Emulator: http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://[YOUR_IP]:8000


# For production, update this to your deployed backend URL
# EXPO_PUBLIC_API_URL=https://api.habithawk.com
